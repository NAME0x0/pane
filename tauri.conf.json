{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pane",
  "version": "0.1.0",
  "identifier": "com.pane.desktop",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Pane",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["assets/pane-icon.ico"]
  }
}
